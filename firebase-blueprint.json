{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "admin", "super-admin"] },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "number" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "address": { "type": "string" },
        "studentId": { "type": "string" },
        "grade": { "type": "string" },
        "fatherName": { "type": "string" },
        "enrolledCourses": { "type": "array", "items": { "type": "string" } },
        "teacherId": { "type": "string" },
        "subject": { "type": "string" },
        "expertise": { "type": "array", "items": { "type": "string" } },
        "assignedClasses": { "type": "array", "items": { "type": "string" } },
        "hardwareStatus": {
          "type": "object",
          "properties": {
            "notifications": { "type": "string", "enum": ["granted", "denied", "prompt", "not-supported"] },
            "camera": { "type": "string", "enum": ["granted", "denied", "prompt", "not-supported"] },
            "microphone": { "type": "string", "enum": ["granted", "denied", "prompt", "not-supported"] },
            "lastUpdated": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["uid", "email", "displayName", "role", "createdAt"]
    },
    "Attendance": {
      "title": "Attendance Record",
      "description": "Stores attendance records for students.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["present", "absent", "late"] },
        "markedBy": { "type": "string" },
        "markedAt": { "type": "number" },
        "grade": { "type": "string" }
      },
      "required": ["studentId", "studentName", "date", "status", "markedBy", "markedAt"]
    },
    "Schedule": {
      "title": "Class Schedule",
      "description": "Defines class timings and rooms.",
      "type": "object",
      "properties": {
        "subject": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "dayOfWeek": { "type": "number" },
        "room": { "type": "string" }
      },
      "required": ["subject", "teacherId", "teacherName", "startTime", "endTime", "dayOfWeek", "room"]
    },
    "Note": {
      "title": "Study Note",
      "description": "Stores metadata for uploaded study notes.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "fileUrl": { "type": "string", "format": "uri" },
        "uploadedBy": { "type": "string" },
        "uploadedAt": { "type": "number" },
        "subject": { "type": "string" },
        "grade": { "type": "string" },
        "authorName": { "type": "string" }
      },
      "required": ["title", "uploadedBy", "uploadedAt", "subject", "grade"]
    },
    "FeeReceipt": {
      "title": "Fee Receipt",
      "description": "Stores fee payment records and approval status.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "teacherId": { "type": "string" },
        "approvedBy": { "type": "string" },
        "approvedAt": { "type": "number" },
        "remarks": { "type": "string" },
        "receiptNumber": { "type": "string" },
        "feeHead": { "type": "string" },
        "paymentMode": { "type": "string" },
        "transactionId": { "type": "string" }
      },
      "required": ["studentId", "studentName", "amount", "date", "status", "teacherId"]
    },
    "Course": {
      "title": "Course Information",
      "description": "Stores course details and curriculum.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "code": { "type": "string" },
        "description": { "type": "string" },
        "credits": { "type": "number" },
        "duration": { "type": "string" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["name", "code", "teacherId", "teacherName", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Stores in-app notifications.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["fee_request", "class_timing", "announcement", "general"] },
        "targetType": { "type": "string", "enum": ["individual", "class", "all"] },
        "targetId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "createdAt": { "type": "number" },
        "readBy": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["title", "message", "type", "targetType", "senderId", "createdAt"]
    },
    "SystemLog": {
      "title": "System Log",
      "description": "Stores application logs for administrative review.",
      "type": "object",
      "properties": {
        "level": { "type": "string", "enum": ["info", "success", "warn", "error", "db", "auth"] },
        "message": { "type": "string" },
        "data": { "type": "object" },
        "timestamp": { "type": "number" },
        "userAgent": { "type": "string" }
      },
      "required": ["level", "message", "timestamp"]
    },
    "InstituteSettings": {
      "title": "Institute Settings",
      "description": "Stores branding and configuration for the institute.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "maktabName": { "type": "string" },
        "tagline": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "logoUrl": { "type": "string" },
        "primaryColor": { "type": "string" },
        "secondaryColor": { "type": "string" },
        "website": { "type": "string" },
        "receiptPrefix": { "type": "string" },
        "mission": { "type": "string" },
        "founded": { "type": "string" },
        "greeting": { "type": "string" }
      },
      "required": ["id", "name", "maktabName"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance records."
    },
    "/schedules/{scheduleId}": {
      "schema": "Schedule",
      "description": "Class schedules."
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "Study notes."
    },
    "/receipts/{receiptId}": {
      "schema": "FeeReceipt",
      "description": "Fee payment records."
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Course information."
    },
    "/notifications/{notifId}": {
      "schema": "Notification",
      "description": "In-app notifications."
    },
    "/settings/{settingId}": {
      "schema": "InstituteSettings",
      "description": "Institute branding and configuration."
    },
    "/system_logs/{logId}": {
      "schema": "SystemLog",
      "description": "Application logs for administrative review."
    }
  }
}
